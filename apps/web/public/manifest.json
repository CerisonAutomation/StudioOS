{
  "name": "StudioOS - Enterprise Interior Design Platform",
  "short_name": "StudioOS",
  "description": "Interior design platform with AI automation, 3D visualization, and professional collaboration tools."
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f0f0f",
  "theme_color": "#6366f1",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en-US",
  "categories": ["productivity", "design", "business"],
  "icons": [
